{
  "name": "02labs",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:blog",
    "dev:www": "npm -w apps/www run dev",
    "dev:blog": "npm -w apps/blog run dev",
    "sync:blog": "./scripts/sync-blog.sh",
    "build:www": "npm -w apps/www run build",
    "build:blog": "npm -w apps/blog run build",
    "preview:www": "npm -w apps/www run preview",
    "preview:blog": "npm -w apps/blog run preview",
    "check:www": "npm -w apps/www run astro check",
    "check:blog": "npm -w apps/blog run astro check"
  }
}
