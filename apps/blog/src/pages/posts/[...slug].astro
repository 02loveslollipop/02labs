---
import PostLayout from "../../layouts/PostLayout.astro";
import { getCollection } from "astro:content";
import {
	BLOG_AUTHOR,
	BLOG_NAME,
	BLOG_PUBLISHER,
	getPostFirstImageSrc,
	getPostSlug,
	getRelatedPosts,
	resolvePostImageSrc,
	resolveSiteUrl,
	stripMarkdownInline,
} from "../../lib/posts";

export async function getStaticPaths() {
	const entries = await getCollection("blog");
	const posts = entries.filter((p) => !p.data.draft);
	return posts.map((entry) => ({
		params: { slug: getPostSlug(entry) },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const slug = getPostSlug(entry);
const titlePlain = stripMarkdownInline(entry.data.title);
const descriptionPlain = stripMarkdownInline(entry.data.description);
const relatedPosts = getRelatedPosts(entry, await getCollection("blog"));
const imageSrc =
	resolvePostImageSrc(entry.data.featuredImage, slug) ??
	getPostFirstImageSrc(entry.body, slug);
const imageUrl = (() => {
	if (!imageSrc) return undefined;
	if (/^https?:\/\//i.test(imageSrc)) return imageSrc;
	if (imageSrc.startsWith("//")) return `https:${imageSrc}`;
	return Astro.site ? new URL(imageSrc, Astro.site).toString() : imageSrc;
})();

const url = resolveSiteUrl(`/posts/${slug}/`, Astro.site);
const blogUrl = resolveSiteUrl("/", Astro.site);
const breadcrumbJsonLd = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: BLOG_NAME,
			item: blogUrl,
		},
		{
			"@type": "ListItem",
			position: 2,
			name: titlePlain,
			item: url,
		},
	],
};
const articleJsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: titlePlain,
	description: descriptionPlain,
	datePublished: entry.data.pubDate.toISOString(),
	dateModified: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": url,
	},
	...(imageUrl ? { image: imageUrl } : {}),
	author: {
		"@type": "Person",
		name: BLOG_AUTHOR.name,
		url: BLOG_AUTHOR.url,
		sameAs: [...BLOG_AUTHOR.sameAs],
	},
	publisher: {
		"@type": "Organization",
		name: BLOG_PUBLISHER.name,
		url: BLOG_PUBLISHER.url,
		logo: {
			"@type": "ImageObject",
			url: resolveSiteUrl(BLOG_PUBLISHER.logoPath, Astro.site),
		},
	},
	keywords: entry.data.tags.join(", "),
	isPartOf: {
		"@type": "Blog",
		name: BLOG_NAME,
		url: blogUrl,
	},
};

const jsonLd = JSON.stringify([articleJsonLd, breadcrumbJsonLd], null, 0);
---

<PostLayout
	title={entry.data.title}
	description={entry.data.description}
	pubDate={entry.data.pubDate}
	updatedDate={entry.data.updatedDate}
	tags={entry.data.tags}
	ogImage={imageUrl}
	ogImageAlt={`${titlePlain} featured image`}
	jsonLd={jsonLd}
	relatedPosts={relatedPosts}
>
	<Content />
</PostLayout>
