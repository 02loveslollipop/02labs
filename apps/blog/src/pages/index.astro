---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
	getPostExcerpt,
	getPostFirstImageSrc,
	getPostSlug,
	resolvePostImageSrc,
	stripMarkdownInline,
} from "../lib/posts";

const entries = await getCollection("blog");
const posts = entries
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((post) => {
		const slug = getPostSlug(post);
		return {
			post,
			slug,
			title: stripMarkdownInline(post.data.title),
			excerpt: getPostExcerpt(post.body, stripMarkdownInline(post.data.description)),
			imageSrc:
				resolvePostImageSrc(post.data.featuredImage, slug) ??
				getPostFirstImageSrc(post.body, slug),
		};
	});
---

<BaseLayout title="02Labs Blog" description="Writeups, notes, and deep dives." ogType="website">
	<header class="header">
		<div class="header__inner">
			<a class="brand" href="/">02Labs Blog</a>
			<nav class="header__links" aria-label="Site">
				<a href="/rss.xml">RSS</a>
				<a href="https://02labs.me/" rel="noopener noreferrer">Main site</a>
			</nav>
		</div>
	</header>

	<main class="wrap">
		<section class="paper" aria-label="Posts">
			<div class="post-list">
				{posts.map(({ post, slug, title, excerpt, imageSrc }) => (
					<a class={`post-item ${imageSrc ? "" : "post-item--no-image"}`} href={`/posts/${slug}/`}>
						{imageSrc ? (
							<img
								class="post-item__thumb"
								src={imageSrc}
								alt={`${title} preview`}
								loading="lazy"
								decoding="async"
							/>
						) : null}
						<div class="post-item__body">
							<h2>{title}</h2>
							<p class="post-item__excerpt">{excerpt}</p>
							<div class="meta">
								<span>{post.data.pubDate.toISOString().slice(0, 10)}</span>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</BaseLayout>
