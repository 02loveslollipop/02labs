---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
	BLOG_AUTHOR,
	BLOG_DESCRIPTION,
	BLOG_LOCALE,
	BLOG_NAME,
	BLOG_PUBLISHER,
	formatDateIso,
	resolveSiteUrl,
	sortBlogEntries,
	toBlogIndexPost,
} from "../lib/posts";

const entries = sortBlogEntries((await getCollection("blog")).filter((p) => !p.data.draft));
const posts = entries.map((post) => ({ entry: post, preview: toBlogIndexPost(post, Astro.site) }));
const blogUrl = resolveSiteUrl("/", Astro.site);
const jsonLd = JSON.stringify(
	[
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			name: BLOG_NAME,
			description: BLOG_DESCRIPTION,
			url: blogUrl,
			inLanguage: BLOG_LOCALE,
		},
		{
			"@context": "https://schema.org",
			"@type": "Blog",
			name: BLOG_NAME,
			description: BLOG_DESCRIPTION,
			url: blogUrl,
			inLanguage: BLOG_LOCALE,
			author: {
				"@type": "Person",
				name: BLOG_AUTHOR.name,
				url: BLOG_AUTHOR.url,
				sameAs: [...BLOG_AUTHOR.sameAs],
			},
			publisher: {
				"@type": "Organization",
				name: BLOG_PUBLISHER.name,
				url: BLOG_PUBLISHER.url,
				logo: {
					"@type": "ImageObject",
					url: resolveSiteUrl(BLOG_PUBLISHER.logoPath, Astro.site),
				},
			},
		},
		{
			"@context": "https://schema.org",
			"@type": "ItemList",
			name: `${BLOG_NAME} Posts`,
			itemListElement: posts.map(({ preview }, index) => ({
				"@type": "ListItem",
				position: index + 1,
				name: preview.title,
				url: preview.url,
			})),
		},
	],
	null,
	0
);
---

<BaseLayout
	title="02loveslollipop's Blog, mostly Crypto CTF writeups/deep dives and whatever I feel like writing about"
	description={BLOG_DESCRIPTION}
	ogType="website"
	jsonLd={jsonLd}
>
	<header class="header">
		<div class="header__inner">
			<a class="brand" href="/">{BLOG_NAME}</a>
			<nav class="header__links" aria-label="Site">
				<a href="/rss.xml">RSS</a>
				<a href="https://02labs.me/" rel="noopener noreferrer">Main site</a>
			</nav>
		</div>
	</header>

	<main class="wrap">
		<section class="paper" aria-label="Posts">
			<header class="archive-hero">
				<p class="archive-hero__eyebrow">{BLOG_NAME}</p>
				<h1>02loveslollipop's Blog, mostly Crypto CTF writeups/deep dives and whatever I feel like writing about</h1>
				<p>
					Long-form breakdowns from 02Labs, authored by 02loveslollipop, covering
					security challenges, investigations, and engineering work.
				</p>
			</header>
			<div class="post-list">
				{posts.map(({ entry, preview }) => (
					<a class={`post-item ${preview.imageSrc ? "" : "post-item--no-image"}`} href={`/posts/${preview.slug}/`}>
						{preview.imageSrc ? (
							<img
								class="post-item__thumb"
								src={preview.imageSrc}
								alt={`${preview.title} preview`}
								loading="lazy"
								decoding="async"
							/>
						) : null}
							<div class="post-item__body">
								<h2>{preview.title}</h2>
								<p class="post-item__excerpt">{preview.excerpt}</p>
								<div class="meta">
									<time datetime={entry.data.pubDate.toISOString()}>{formatDateIso(entry.data.pubDate)}</time>
								</div>
							</div>
						</a>
				))}
			</div>
		</section>
	</main>
</BaseLayout>
