---
import { getCollection } from "astro:content";
import archiveSettings from "../data/archive-settings.json";
import ArchiveTagBar from "../components/ArchiveTagBar.astro";
import EmptyFeaturedMedia from "../components/EmptyFeaturedMedia.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
	BLOG_AUTHOR,
	BLOG_DESCRIPTION,
	BLOG_LOCALE,
	BLOG_NAME,
	BLOG_PUBLISHER,
	getTagSummaries,
	resolveSiteUrl,
	sortBlogEntries,
	toBlogIndexPost,
} from "../lib/posts";

const entries = sortBlogEntries((await getCollection("blog")).filter((entry) => !entry.data.draft));
const posts = entries.map((entry) => ({ entry, preview: toBlogIndexPost(entry, Astro.site) }));
const configuredFeaturedSlug = String(archiveSettings.featuredSlug || "").trim();
const featured =
	posts.find(({ preview }) => preview.slug === configuredFeaturedSlug) ??
	posts[0] ??
	null;
const archivePosts = featured
	? posts.filter(({ preview }) => preview.slug !== featured.preview.slug)
	: posts;
const tagSummaries = getTagSummaries(entries);
const blogUrl = resolveSiteUrl("/", Astro.site);
const jsonLd = JSON.stringify(
	[
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			name: BLOG_NAME,
			description: BLOG_DESCRIPTION,
			url: blogUrl,
			inLanguage: BLOG_LOCALE,
		},
		{
			"@context": "https://schema.org",
			"@type": "Blog",
			name: BLOG_NAME,
			description: BLOG_DESCRIPTION,
			url: blogUrl,
			inLanguage: BLOG_LOCALE,
			author: {
				"@type": "Person",
				name: BLOG_AUTHOR.name,
				url: BLOG_AUTHOR.url,
				sameAs: [...BLOG_AUTHOR.sameAs],
			},
			publisher: {
				"@type": "Organization",
				name: BLOG_PUBLISHER.name,
				url: BLOG_PUBLISHER.url,
				logo: {
					"@type": "ImageObject",
					url: resolveSiteUrl(BLOG_PUBLISHER.logoPath, Astro.site),
				},
			},
		},
		{
			"@context": "https://schema.org",
			"@type": "ItemList",
			name: `${BLOG_NAME} Posts`,
			itemListElement: posts.map(({ preview }, index) => ({
				"@type": "ListItem",
				position: index + 1,
				name: preview.title,
				url: preview.url,
			})),
		},
	],
	null,
	0
);
---

<BaseLayout title="Blog" description={BLOG_DESCRIPTION} ogType="website" jsonLd={jsonLd}>
	<SiteHeader />

	<main class="wrap" id="main">
		<section class="arc-hero">
			<div class="eyebrow">
				<span>02Labs</span>
				<span class="dot"></span>
				<span>THE BLOG</span>
			</div>
			<h1>02loveslollipop's Blog</h1>
			<p>
				Mostly Crypto CTF writeups/deep dives and whatever I feel like writing about
			</p>
		</section>

		<ArchiveTagBar allCount={posts.length} tagSummaries={tagSummaries} />

		{featured ? (
			<a class="featured" href={`/posts/${featured.preview.slug}/`}>
				<div class="featured__img">
					{featured.preview.imageSrc ? (
						<img
							src={featured.preview.imageSrc}
							alt={`${featured.preview.title} preview`}
							loading="eager"
							decoding="async"
						/>
					) : (
						<EmptyFeaturedMedia />
					)}
				</div>
				<div class="featured__body">
					<div>
						<div class="featured__tags">
							{featured.preview.tags.slice(0, 3).map((tag, index) => (
								<span class={index === 0 ? "tag-a" : "tag-g"}>{tag}</span>
							))}
						</div>
						<div style="height: 18px" aria-hidden="true"></div>
						<h2>{featured.preview.title}</h2>
						<div style="height: 14px" aria-hidden="true"></div>
						<p>{featured.preview.excerpt}</p>
					</div>
					<div class="featured__foot">
						<span>{featured.preview.pubDateDisplay} · {featured.preview.readTimeLabel}</span>
						<span class="cta">READ POST →</span>
					</div>
				</div>
			</a>
		) : null}

		<div class="list" role="list">
			{archivePosts.map(({ preview }, index) => (
				<a class="post-row" href={`/posts/${preview.slug}/`} role="listitem">
					<span class="pr-num">
						{String(index + 1).padStart(2, "0")} · {preview.pubDateCode}
					</span>
					<span class="pr-cat">
						{preview.tags.slice(0, 2).map((tag) => tag.toUpperCase()).join(" · ")}
					</span>
					<span class="pr-title">{preview.title}</span>
					<span class="pr-meta">
						<span>{preview.readTimeLabel}</span>
						<span>{preview.pubDateDisplay.replace(",", "")}</span>
					</span>
					<span class="pr-arrow">→</span>
				</a>
			))}
		</div>

		<footer class="arc-foot">
			<span>END OF ARCHIVE · {String(posts.length).padStart(2, "0")} POSTS</span>
			<a href="/rss.xml">RSS FEED →</a>
		</footer>
	</main>
</BaseLayout>
