---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
	BLOG_DESCRIPTION,
	BLOG_NAME,
	getPostExcerpt,
	getPostFirstImageSrc,
	getPostSlug,
	resolvePostImageSrc,
	resolveSiteUrl,
	slugifyTag,
	sortBlogEntries,
	stripMarkdownInline,
} from "../../lib/posts";

export async function getStaticPaths() {
	const entries = (await getCollection("blog")).filter((entry) => !entry.data.draft);
	const tagMap = new Map<string, string>();

	for (const entry of entries) {
		for (const tag of entry.data.tags) {
			const slug = slugifyTag(tag);
			if (slug && !tagMap.has(slug)) tagMap.set(slug, tag);
		}
	}

	return Array.from(tagMap.entries()).map(([tag, label]) => ({
		params: { tag },
		props: { tagSlug: tag, tagLabel: label },
	}));
}

const { tagSlug, tagLabel } = Astro.props;
const entries = sortBlogEntries((await getCollection("blog")).filter((entry) => !entry.data.draft));
const posts = entries
	.filter((post) => post.data.tags.some((tag) => slugifyTag(tag) === tagSlug))
	.map((post) => {
		const slug = getPostSlug(post);
		return {
			post,
			slug,
			title: stripMarkdownInline(post.data.title),
			excerpt: getPostExcerpt(post.body, stripMarkdownInline(post.data.description)),
			imageSrc:
				resolvePostImageSrc(post.data.featuredImage, slug) ??
				getPostFirstImageSrc(post.body, slug),
		};
	});
const title = `Posts tagged ${tagLabel}`;
const description = `Browse ${posts.length} ${tagLabel} post${posts.length === 1 ? "" : "s"} on ${BLOG_NAME}. ${BLOG_DESCRIPTION}`;
const pageUrl = resolveSiteUrl(`/tags/${tagSlug}/`, Astro.site);
const jsonLd = JSON.stringify(
	[
		{
			"@context": "https://schema.org",
			"@type": "CollectionPage",
			name: title,
			description,
			url: pageUrl,
			isPartOf: {
				"@type": "Blog",
				name: BLOG_NAME,
				url: resolveSiteUrl("/", Astro.site),
			},
		},
		{
			"@context": "https://schema.org",
			"@type": "ItemList",
			name: `${tagLabel} posts`,
			itemListElement: posts.map(({ slug, title: postTitle }, index) => ({
				"@type": "ListItem",
				position: index + 1,
				name: postTitle,
				url: resolveSiteUrl(`/posts/${slug}/`, Astro.site),
			})),
		},
	],
	null,
	0
);
---

<BaseLayout title={title} description={description} ogType="website" jsonLd={jsonLd}>
	<header class="header">
		<div class="header__inner">
			<a class="brand" href="/">{BLOG_NAME}</a>
			<nav class="header__links" aria-label="Site">
				<a href="/rss.xml">RSS</a>
				<a href="https://02labs.me/" rel="noopener noreferrer">Main site</a>
			</nav>
		</div>
	</header>

	<main class="wrap">
		<section class="paper" aria-label={`Posts tagged ${tagLabel}`}>
			<header class="archive-hero">
				<p class="archive-hero__eyebrow">Tag archive</p>
				<h1>{tagLabel}</h1>
				<p>{description}</p>
			</header>

			<div class="post-list">
				{posts.map(({ post, slug, title: postTitle, excerpt, imageSrc }) => (
					<a class={`post-item ${imageSrc ? "" : "post-item--no-image"}`} href={`/posts/${slug}/`}>
						{imageSrc ? (
							<img
								class="post-item__thumb"
								src={imageSrc}
								alt={`${postTitle} preview`}
								loading="lazy"
								decoding="async"
							/>
						) : null}
						<div class="post-item__body">
							<h2>{postTitle}</h2>
							<p class="post-item__excerpt">{excerpt}</p>
							<div class="meta">
								<span>{post.data.pubDate.toISOString().slice(0, 10)}</span>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</BaseLayout>
