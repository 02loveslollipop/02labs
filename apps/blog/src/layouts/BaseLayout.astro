---
import Background from "../components/Background.astro";
import "../styles/global.css";

export interface Props {
	title?: string;
	description?: string;
	ogType?: "website" | "article";
	jsonLd?: string;
}

const {
	title = "02Labs Blog",
	description = "Writeups, notes, and deep dives.",
	ogType = "website",
	jsonLd,
} = Astro.props;

const site = Astro.site;
const canonicalUrl = site ? new URL(Astro.url.pathname, site).toString() : Astro.url.toString();
const fullTitle = title === "02Labs Blog" ? title : `${title} | 02Labs Blog`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />

		<meta name="robots" content="index,follow" />
		<meta name="theme-color" content="#0b0b10" />

		<meta property="og:site_name" content="02Labs Blog" />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl} />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet" />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />

		{jsonLd ? <script type="application/ld+json" is:inline set:html={jsonLd} /> : null}
	</head>
	<body>
		<Background />
		<slot />
	</body>
</html>
