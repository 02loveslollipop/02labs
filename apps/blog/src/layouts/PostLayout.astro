---
import BaseLayout from "./BaseLayout.astro";
import { renderInlineMarkdown, stripMarkdownInline } from "../lib/posts";

export interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
	jsonLd?: string;
}

const { title, description, pubDate, updatedDate, tags, jsonLd } = Astro.props;
const published = pubDate.toISOString().slice(0, 10);
const updated = updatedDate ? updatedDate.toISOString().slice(0, 10) : null;
const titlePlain = stripMarkdownInline(title);
const descriptionPlain = stripMarkdownInline(description);
const titleHtml = renderInlineMarkdown(title);
const descriptionHtml = renderInlineMarkdown(description);
---

<BaseLayout title={titlePlain} description={descriptionPlain} ogType="article" jsonLd={jsonLd}>
	<header class="header">
		<div class="header__inner">
			<a class="brand" href="/">02Labs Blog</a>
			<nav class="header__links" aria-label="Site">
				<a href="/rss.xml">RSS</a>
				<a href="https://02labs.me/" rel="noopener noreferrer">Main site</a>
			</nav>
		</div>
	</header>

	<main class="wrap">
		<article class="paper article">
			<h1 set:html={titleHtml}></h1>
			<p class="lede" set:html={descriptionHtml}></p>

			<div class="meta">
				<span>Published {published}</span>
				{updated ? <span> · Updated {updated}</span> : null}
				{Array.isArray(tags) && tags.length > 0 ? <span> · {tags.join(", ")}</span> : null}
			</div>

			<div style="height: 18px" aria-hidden="true"></div>
			<slot />

			<p class="footer">
				<a href="/">Back to all posts</a>
			</p>
		</article>
	</main>
</BaseLayout>
