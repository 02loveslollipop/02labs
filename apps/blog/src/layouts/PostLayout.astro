---
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "./BaseLayout.astro";
import {
	BLOG_AUTHOR,
	BLOG_TWITTER_HANDLE,
	formatDisplayDate,
	orderDisplayTags,
	renderInlineMarkdown,
	slugifyTag,
	type RelatedPostPreview,
	type TocHeading,
} from "../lib/posts";

export interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
	ogImage?: string;
	ogImageAlt?: string;
	jsonLd?: string;
	relatedPosts?: RelatedPostPreview[];
	readTimeLabel: string;
	heroImageSrc?: string;
	heroImageAlt?: string;
	tocItems?: TocHeading[];
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	tags,
	ogImage,
	ogImageAlt,
	jsonLd,
	relatedPosts = [],
	readTimeLabel,
	heroImageSrc,
	heroImageAlt,
	tocItems = [],
} = Astro.props;

const published = formatDisplayDate(pubDate);
const updated = updatedDate ? formatDisplayDate(updatedDate) : null;
const titleHtml = renderInlineMarkdown(title);
const descriptionHtml = renderInlineMarkdown(description);
const tagLinks = Array.isArray(tags) ? orderDisplayTags(tags) : [];
const articleNavLinks = relatedPosts.slice(0, 2).map((post, index) => ({
	...post,
	kicker: index === 0 ? "Related post" : "Keep reading",
}));
---

<BaseLayout
	title={title}
	description={description}
	ogType="article"
	ogImage={ogImage}
	ogImageAlt={ogImageAlt}
	jsonLd={jsonLd}
	authorName={BLOG_AUTHOR.name}
	publishedTime={pubDate.toISOString()}
	modifiedTime={(updatedDate ?? pubDate).toISOString()}
	articleTags={tags}
	twitterSite={BLOG_TWITTER_HANDLE}
	twitterCreator={BLOG_TWITTER_HANDLE}
>
	<SiteHeader />

	<main class="wrap">
		<section class="hero">
			{tagLinks.length > 0 ? (
				<div class="article-tags" aria-label="Tags">
					{tagLinks.map((tag, index) => (
						<a class={index === 0 ? "tag tag--solid" : "tag tag--ghost"} href={`/tags/${slugifyTag(tag)}/`}>
							{tag}
						</a>
					))}
				</div>
			) : null}

			<h1 class="title" set:html={titleHtml}></h1>
			<p class="lede" set:html={descriptionHtml}></p>

			<div class="meta-bar">
					<span>
						<span class="k">DATE</span>
						<time datetime={pubDate.toISOString()}>{published}</time>
					</span>
				{updated ? (
					<span>
						<span class="k">UPDATED</span>
						<time datetime={updatedDate?.toISOString()}>{updated}</time>
					</span>
				) : null}
				<span><span class="k">READ</span>{readTimeLabel}</span>
				{tagLinks.length > 0 ? (
					<span class="tags">
						{tagLinks.map((tag) => (
							<a href={`/tags/${slugifyTag(tag)}/`}>#{tag.toUpperCase().replaceAll(" ", "-")}</a>
						))}
					</span>
				) : null}
			</div>

			{heroImageSrc ? (
				<figure class="figure">
					<div class="figure__img">
						<img
							src={heroImageSrc}
							alt={heroImageAlt ?? `${title} featured image`}
							loading="eager"
							decoding="async"
						/>
					</div>
					<figcaption class="figure__cap">
						{heroImageAlt ?? `${title} featured image`}
					</figcaption>
				</figure>
			) : null}
		</section>

		<div class:list={["article-grid", { "article-grid--no-toc": tocItems.length === 0 }]}>
			{tocItems.length > 0 ? (
				<aside class="toc" aria-label="Table of contents" id="toc">
					<div class="toc__label">Contents</div>
					<div class="toc__items">
						{tocItems.map((item) => (
							<a
								class={`toc__link toc__link--depth-${Math.min(item.depth, 3)}`}
								data-toc-link
								href={`#${item.id}`}
							>
								{item.text}
							</a>
						))}
					</div>
				</aside>
			) : null}

			<article class="prose" id="articleContent">
				<slot />

				{articleNavLinks.length > 0 ? (
					<section class="article-foot" aria-label="Further reading">
						{articleNavLinks.map((post) => (
							<a class="nav-link" href={`/posts/${post.slug}/`}>
								<span class="k">{post.kicker}</span>
								<span class="t">{post.title}</span>
							</a>
						))}
					</section>
				) : null}

				<a class="back-link" href="/">BACK TO ARCHIVE →</a>
			</article>
		</div>
	</main>

	<script is:inline>
		(() => {
			const article = document.getElementById("articleContent");
			const toc = document.getElementById("toc");
			if (!(article instanceof HTMLElement)) return;

			const fitProseImages = () => {
				const viewportMaxHeight = window.innerHeight * 0.7;
				const images = Array.from(article.querySelectorAll("img"));

				for (const image of images) {
					if (!(image instanceof HTMLImageElement)) continue;
					if (image.closest("figure")) continue;

					const parent = image.parentElement;
					if (!(parent instanceof HTMLElement)) continue;
					if (image.naturalWidth <= 0 || image.naturalHeight <= 0) continue;

					const availableWidth = parent.clientWidth;
					if (availableWidth <= 0) continue;

					const widthScale = availableWidth / image.naturalWidth;
					const heightScale = viewportMaxHeight / image.naturalHeight;
					const targetScale = Math.max(0.01, Math.min(widthScale, heightScale));
					const targetWidth = Math.max(1, Math.floor(image.naturalWidth * targetScale));

					image.style.width = `${targetWidth}px`;
					image.style.height = "auto";
					image.dataset.autofitReady = "true";
				}
			};

			const initProseImages = () => {
				const images = Array.from(article.querySelectorAll("img"));
				for (const image of images) {
					if (!(image instanceof HTMLImageElement)) continue;
					if (image.closest("figure")) continue;
					if (image.complete) continue;
					image.addEventListener("load", fitProseImages, { once: true });
				}
				fitProseImages();
			};

			let resizeRaf = 0;
			const onResize = () => {
				if (resizeRaf) cancelAnimationFrame(resizeRaf);
				resizeRaf = requestAnimationFrame(() => {
					fitProseImages();
					resizeRaf = 0;
				});
			};

			window.addEventListener("resize", onResize, { passive: true });
			window.addEventListener("orientationchange", onResize, { passive: true });
			initProseImages();

			if (!(toc instanceof HTMLElement)) return;

			const links = Array.from(toc.querySelectorAll("[data-toc-link]"));
			const headings = Array.from(article.querySelectorAll("h1, h2, h3"));

			if (headings.length === 0 || links.length === 0) {
				toc.hidden = true;
				return;
			}

			headings.forEach((heading, index) => {
				const link = links[index];
				if (!(heading instanceof HTMLElement) || !(link instanceof HTMLAnchorElement)) return;
				const targetId = link.getAttribute("href")?.replace(/^#/, "");
				if (targetId && heading.id !== targetId) heading.id = targetId;
				link.setAttribute("href", `#${heading.id}`);
			});

			const observer = new IntersectionObserver(
				(entries) => {
					const visible = entries
						.filter((entry) => entry.isIntersecting)
						.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
					if (!visible?.target.id) return;
					for (const link of links) {
						link.classList.toggle("on", link.getAttribute("href") === `#${visible.target.id}`);
					}
				},
				{
					rootMargin: "-20% 0px -55% 0px",
					threshold: 0.1,
				}
			);

			for (const heading of headings) {
				if (heading instanceof HTMLElement) observer.observe(heading);
			}
		})();
	</script>
</BaseLayout>
