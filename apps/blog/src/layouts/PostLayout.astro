---
import BaseLayout from "./BaseLayout.astro";
import {
	BLOG_AUTHOR,
	BLOG_NAME,
	BLOG_TWITTER_HANDLE,
	formatDateIso,
	renderInlineMarkdown,
	slugifyTag,
	stripMarkdownInline,
	type RelatedPostPreview,
} from "../lib/posts";

export interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
	ogImage?: string;
	ogImageAlt?: string;
	jsonLd?: string;
	relatedPosts?: RelatedPostPreview[];
}

const { title, description, pubDate, updatedDate, tags, ogImage, ogImageAlt, jsonLd, relatedPosts } = Astro.props;
const published = formatDateIso(pubDate);
const updated = updatedDate ? formatDateIso(updatedDate) : null;
const titlePlain = stripMarkdownInline(title);
const descriptionPlain = stripMarkdownInline(description);
const titleHtml = renderInlineMarkdown(title);
const descriptionHtml = renderInlineMarkdown(description);
---

<BaseLayout
	title={titlePlain}
	description={descriptionPlain}
	ogType="article"
	ogImage={ogImage}
	ogImageAlt={ogImageAlt}
	jsonLd={jsonLd}
	authorName={BLOG_AUTHOR.name}
	publishedTime={pubDate.toISOString()}
	modifiedTime={(updatedDate ?? pubDate).toISOString()}
	articleTags={tags}
	twitterSite={BLOG_TWITTER_HANDLE}
	twitterCreator={BLOG_TWITTER_HANDLE}
>
	<header class="header">
		<div class="header__inner">
			<a class="brand" href="/">{BLOG_NAME}</a>
			<nav class="header__links" aria-label="Site">
				<a href="/rss.xml">RSS</a>
				<a href="https://02labs.me/" rel="noopener noreferrer">Main site</a>
			</nav>
		</div>
	</header>

	<main class="wrap">
		<article class="paper article">
			<h1 set:html={titleHtml}></h1>
			<p class="lede" set:html={descriptionHtml}></p>

			<div class="meta">
				<span>
					Published <time datetime={pubDate.toISOString()}>{published}</time>
				</span>
				{updatedDate ? (
					<span>
						{" "}· Updated <time datetime={updatedDate.toISOString()}>{updated}</time>
					</span>
				) : null}
			</div>
			{Array.isArray(tags) && tags.length > 0 ? (
				<div class="article-tags" aria-label="Tags">
					{tags.map((tag) => (
						<a class="tag-pill" href={`/tags/${slugifyTag(tag)}/`}>
							{tag}
						</a>
					))}
				</div>
			) : null}

			<div style="height: 18px" aria-hidden="true"></div>
			<slot />

			{Array.isArray(relatedPosts) && relatedPosts.length > 0 ? (
				<section class="related-posts" aria-label="Related posts">
					<h2>Related posts</h2>
					<div class="related-posts__list">
						{relatedPosts.map((post) => (
							<a class="related-post" href={`/posts/${post.slug}/`}>
								<h3>{post.title}</h3>
								<p>{post.excerpt}</p>
								<div class="meta">
									<time datetime={post.pubDate.toISOString()}>{formatDateIso(post.pubDate)}</time>
								</div>
							</a>
						))}
					</div>
				</section>
			) : null}

			<p class="footer">
				<a href="/">Back to all posts</a>
			</p>
		</article>
	</main>
</BaseLayout>
