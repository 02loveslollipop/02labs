<div class="featured__img--empty featured-empty" data-featured-empty>
	<canvas class="featured-empty__canvas" aria-hidden="true"></canvas>
	<div class="featured-empty__content">
		<span class="featured-empty__label">No featured image</span>
	</div>
</div>

<script>
	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
	const roots = Array.from(document.querySelectorAll("[data-featured-empty]"));

	function clamp(value, min, max) {
		return Math.max(min, Math.min(max, value));
	}

	function randomBetween(min, max) {
		return min + Math.random() * (max - min);
	}

	for (const root of roots) {
		if (!(root instanceof HTMLElement) || root.dataset.animated === "true") continue;
		root.dataset.animated = "true";

		const canvas = root.querySelector(".featured-empty__canvas");
		if (!(canvas instanceof HTMLCanvasElement)) continue;

		const context = canvas.getContext("2d");
		if (!context) continue;

		const pointer = {
			active: false,
			x: 0,
			y: 0,
			vx: 0,
			vy: 0,
			lastX: 0,
			lastY: 0,
		};
		const scrollImpulse = { x: 0, y: 0 };
		let width = 0;
		let height = 0;
		let columns = 0;
		let rows = 0;
		let spacingX = 0;
		let spacingY = 0;
		let maxOffset = 0;
		let rafId = 0;
		let lastTimestamp = 0;
		let nodes = [];

		function rebuild() {
			const rect = root.getBoundingClientRect();
			const dpr = Math.min(window.devicePixelRatio || 1, 2);
			width = Math.max(1, Math.round(rect.width));
			height = Math.max(1, Math.round(rect.height));
			canvas.width = Math.round(width * dpr);
			canvas.height = Math.round(height * dpr);
			canvas.style.width = `${width}px`;
			canvas.style.height = `${height}px`;
			context.setTransform(dpr, 0, 0, dpr, 0, 0);

			columns = clamp(Math.round(width / 68), 7, 12);
			rows = clamp(Math.round(height / 58), 5, 9);
			spacingX = width / (columns + 1);
			spacingY = height / (rows + 1);
			maxOffset = Math.min(spacingX, spacingY) * 0.28;
			nodes = [];

			for (let row = 0; row < rows; row += 1) {
				for (let column = 0; column < columns; column += 1) {
					const x =
						spacingX * (column + 1) + randomBetween(-spacingX * 0.28, spacingX * 0.28);
					const y =
						spacingY * (row + 1) + randomBetween(-spacingY * 0.28, spacingY * 0.28);
					const driftAngle = randomBetween(0, Math.PI * 2);
					const driftAngleB = randomBetween(0, Math.PI * 2);
					const connectionBoost = Math.random() < 0.26 ? randomBetween(1.25, 1.65) : 1;
					nodes.push({
						baseX: x,
						baseY: y,
						x,
						y,
						drawX: x,
						drawY: y,
						offsetX: 0,
						offsetY: 0,
						impulseX: 0,
						impulseY: 0,
						phase: randomBetween(0, Math.PI * 2),
						phaseB: randomBetween(0, Math.PI * 2),
						speed: randomBetween(0.48, 1.18),
						speedB: randomBetween(0.26, 0.94),
						strength: randomBetween(0.55, 1.18),
						strengthB: randomBetween(0.18, 0.7),
						driftAngle,
						driftAngleB,
						driftRadius: randomBetween(maxOffset * 0.32, maxOffset * 1.1),
						driftRadiusB: randomBetween(maxOffset * 0.14, maxOffset * 0.7),
						connectionRadius: Math.min(spacingX, spacingY) * randomBetween(1.18, 1.42) * connectionBoost,
						glowRadius: randomBetween(1.6, 3.9),
						dotRadius: randomBetween(0.4, 1.3),
						alpha: randomBetween(0.68, 0.98),
					});
				}
			}
		}

		function updatePointer(event) {
			const rect = root.getBoundingClientRect();
			const nextX = event.clientX - rect.left;
			const nextY = event.clientY - rect.top;
			pointer.vx += nextX - pointer.lastX;
			pointer.vy += nextY - pointer.lastY;
			pointer.x = nextX;
			pointer.y = nextY;
			pointer.lastX = nextX;
			pointer.lastY = nextY;
			pointer.active = true;
		}

		function onPointerEnter(event) {
			const rect = root.getBoundingClientRect();
			pointer.lastX = event.clientX - rect.left;
			pointer.lastY = event.clientY - rect.top;
			pointer.x = pointer.lastX;
			pointer.y = pointer.lastY;
			pointer.vx = 0;
			pointer.vy = 0;
			pointer.active = true;
		}

		function onPointerLeave() {
			pointer.active = false;
		}

		function onWheel(event) {
			const rect = root.getBoundingClientRect();
			const insideX = event.clientX >= rect.left && event.clientX <= rect.right;
			const insideY = event.clientY >= rect.top && event.clientY <= rect.bottom;
			if (!insideX || !insideY) return;
			scrollImpulse.x += event.deltaX * 0.02;
			scrollImpulse.y += event.deltaY * 0.012;
		}

		function getWaveStrength(x, y, time) {
			const nx = x / Math.max(width, 1);
			const ny = y / Math.max(height, 1);
			const diagonalBand = Math.sin((nx * 8.2) - (ny * 6.4) - time * 1.8);
			const crossBand = Math.sin((nx * 5.1) + (ny * 7.4) - time * 1.15 + 1.3);
			const radialBand = Math.sin(Math.hypot(nx - 0.52, ny - 0.48) * 14.5 - time * 2.25);
			const combined = diagonalBand * 0.5 + crossBand * 0.28 + radialBand * 0.22;
			return clamp((combined + 1) * 0.5, 0, 1);
		}

		function render(timestamp) {
			if (!lastTimestamp) lastTimestamp = timestamp;
			const dt = clamp((timestamp - lastTimestamp) / 16.6667, 0.6, 1.8);
			lastTimestamp = timestamp;
			context.clearRect(0, 0, width, height);

			const t = timestamp * 0.001;
			const influenceRadius = Math.min(spacingX, spacingY) * 2.3;

			scrollImpulse.x *= Math.pow(0.92, dt);
			scrollImpulse.y *= Math.pow(0.9, dt);
			pointer.vx *= Math.pow(0.74, dt);
			pointer.vy *= Math.pow(0.74, dt);

			for (const node of nodes) {
				const waveX =
					Math.cos(t * node.speed + node.phase + node.driftAngle) * node.driftRadius * node.strength +
					Math.sin(t * node.speedB + node.phaseB + node.driftAngleB) * node.driftRadiusB +
					Math.cos((t * 0.46) + (node.baseY / Math.max(height, 1)) * 4.1) * maxOffset * 0.2;
				const waveY =
					Math.sin((t * node.speed * 0.9) + node.phase + node.driftAngle) * node.driftRadius * node.strengthB +
					Math.cos((t * node.speedB * 1.08) + node.phaseB + node.driftAngleB) * node.driftRadiusB +
					Math.sin((t * 0.42) + (node.baseX / Math.max(width, 1)) * 3.7) * maxOffset * 0.22;

				node.offsetX += (waveX - node.offsetX) * 0.12 * dt;
				node.offsetY += (waveY - node.offsetY) * 0.12 * dt;

				node.impulseX += scrollImpulse.x * 0.05;
				node.impulseY += scrollImpulse.y * 0.05;

				if (pointer.active) {
					const dx = node.baseX - pointer.x;
					const dy = node.baseY - pointer.y;
					const distance = Math.hypot(dx, dy) || 1;
					if (distance < influenceRadius) {
						const falloff = 1 - distance / influenceRadius;
						node.impulseX += pointer.vx * 0.12 * falloff;
						node.impulseY += pointer.vy * 0.12 * falloff;
					}
				}

				node.impulseX *= Math.pow(0.84, dt);
				node.impulseY *= Math.pow(0.84, dt);
				node.x = node.baseX + node.offsetX + node.impulseX;
				node.y = node.baseY + node.offsetY + node.impulseY;
				node.drawX += (node.x - node.drawX) * 0.24 * dt;
				node.drawY += (node.y - node.drawY) * 0.24 * dt;
			}

			for (let index = 0; index < nodes.length; index += 1) {
				const node = nodes[index];
				for (let next = index + 1; next < nodes.length; next += 1) {
					const other = nodes[next];
					const dx = other.drawX - node.drawX;
					const dy = other.drawY - node.drawY;
					const distance = Math.hypot(dx, dy);
					const neighborhood = Math.max(node.connectionRadius, other.connectionRadius);
					if (distance > neighborhood) continue;

					const midpointX = (node.drawX + other.drawX) * 0.5;
					const midpointY = (node.drawY + other.drawY) * 0.5;
					const waveStrength = getWaveStrength(midpointX, midpointY, t);
					const waveThreshold = 0.73;
					if (waveStrength <= waveThreshold) continue;

					const alpha = 1 - distance / neighborhood;
					const waveAlpha = (waveStrength - waveThreshold) / (1 - waveThreshold);
					context.beginPath();
					context.moveTo(node.drawX, node.drawY);
					context.lineTo(other.drawX, other.drawY);
					context.strokeStyle = `rgba(45, 108, 255, ${0.05 + alpha * 0.12 + waveAlpha * 0.22})`;
					context.lineWidth = 0.75 + alpha * 0.35 + waveAlpha * 0.7;
					context.stroke();
				}
			}

			for (const node of nodes) {
				context.beginPath();
				context.arc(node.drawX, node.drawY, node.dotRadius, 0, Math.PI * 2);
				context.fillStyle = `rgba(45, 108, 255, ${node.alpha})`;
				context.fill();

				context.beginPath();
				context.arc(node.drawX, node.drawY, node.glowRadius, 0, Math.PI * 2);
				context.fillStyle = `rgba(45, 108, 255, ${0.045 + node.alpha * 0.05})`;
				context.fill();
			}

			rafId = window.requestAnimationFrame(render);
		}

		rebuild();

		if (!prefersReducedMotion.matches) {
			rafId = window.requestAnimationFrame(render);
		} else {
			render(0);
		}

		const resizeObserver = new ResizeObserver(() => rebuild());
		resizeObserver.observe(root);
		root.addEventListener("pointerenter", onPointerEnter);
		root.addEventListener("pointermove", updatePointer);
		root.addEventListener("pointerleave", onPointerLeave);
		window.addEventListener("wheel", onWheel, { passive: true });

		root.addEventListener(
			"astro:unmount",
			() => {
				if (rafId) window.cancelAnimationFrame(rafId);
				resizeObserver.disconnect();
				root.removeEventListener("pointerenter", onPointerEnter);
				root.removeEventListener("pointermove", updatePointer);
				root.removeEventListener("pointerleave", onPointerLeave);
				window.removeEventListener("wheel", onWheel);
			},
			{ once: true }
		);
	}
</script>
