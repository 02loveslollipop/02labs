---
export interface Props {
	rightText?: string;
	forceScrolled?: boolean;
	githubHref?: string;
}

const {
	rightText = "",
	forceScrolled = false,
	githubHref = "https://github.com/02loveslollipop",
} = Astro.props;
---

<nav
	class="nav"
	id="siteNav"
	aria-label="Primary"
	data-scrolled={forceScrolled ? "true" : undefined}
>
	<div class="nav__inner">
		<a class="nav__brand" href="/#top" data-animate="nav-brand">
			02Labs
		</a>
		<div class="nav__links" data-animate="nav-links">
			<a href="/#top">Home</a>
			<a href="/#featured">Featured</a>
			<a href="/#blog">Blog</a>
			<a href="/projects/">Projects</a>
		</div>
		<div class="nav__actions">
			{rightText ? (
				<span class="nav__meta" aria-hidden="true">
					{rightText}
				</span>
			) : null}
			<a
				class="nav__github"
				href={githubHref}
				target="_blank"
				rel="noopener noreferrer"
				data-animate="nav-github"
				aria-label="Open GitHub profile"
			>
				GitHub
			</a>
		</div>
	</div>
</nav>
