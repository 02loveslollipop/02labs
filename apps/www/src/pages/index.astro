---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProjectDetail from "../components/ProjectDetail.astro";
import { getCollection } from "astro:content";
import type { CTFTimeData } from "./api/ctftime.json";

// ---------- Server-side KV read ----------
const kv = Astro.locals.runtime?.env?.CTFTIME_KV;
let ctf: CTFTimeData | null = null;
if (kv) {
	try {
		const raw = await kv.get("ctftime_data");
		if (raw) ctf = JSON.parse(raw) as CTFTimeData;
	} catch {
		// fall through to static fallback
	}
}

// Static fallback used on first deploy / before first sync
const fallbackTeam = {
	rating_place: 40,
	country_place: 1,
	rating_points: 121.352,
};
const fallbackEvents = [
	{ event_id: "3043", title: "Srdnlen CTF 2026 Quals",       place: 131, ctf_points: "250.0000",   time: 0 },
	{ event_id: "3127", title: "EHAX CTF 2026",                 place: 24,  ctf_points: "5312.0000",  time: 0 },
	{ event_id: "3098", title: "Batman's Kitchen CTF 2026",     place: 10,  ctf_points: "10689.0000", time: 0 },
	{ event_id: "3122", title: "BITSCTF 2026",                  place: 31,  ctf_points: "2672.0000",  time: 0 },
	{ event_id: "3086", title: "TaipanByte\u2019s Chart CTF",   place: 34,  ctf_points: "5730.0000",  time: 0 },
	{ event_id: "3081", title: "0xFUN CTF 2026",                place: 291, ctf_points: "1903.0000",  time: 0 },
	{ event_id: "3066", title: "Nullcon Goa HackIM 2026 CTF",   place: 12,  ctf_points: "5262.0000",  time: 0 },
	{ event_id: "2767", title: "PascalCTF 2026",                place: 63,  ctf_points: "6413.0000",  time: 0 },
];

const team    = ctf?.team    ?? fallbackTeam;
const events  = ctf?.events  ?? fallbackEvents;
const ctfYear = ctf?.year    ?? new Date().getUTCFullYear();

const entries = await getCollection("projects");
const projects = entries.map((e) => e.data).sort((a, b) => a.order - b.order);
const featured = projects.filter((p) => p.featured).slice(0, 5);

const jsonLd = JSON.stringify(
	[
		{
			"@context": "https://schema.org",
			"@type": "Person",
			name: "02loveslollipop",
			jobTitle: "Computer and systems engineer & Data science engineer",
			url: "https://02labs.me/",
		},
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			name: "02Labs",
			url: "https://02labs.me/",
		},
	],
	null,
	0
);

// ---------- Blog RSS fetch ----------
interface BlogPost {
	title: string;
	description: string;
	link: string;
	pubDate: string;
}

function parseRssItems(xml: string): BlogPost[] {
	const items: BlogPost[] = [];
	const itemRe = /<item>([\s\S]*?)<\/item>/g;
	let m: RegExpExecArray | null;
	while ((m = itemRe.exec(xml)) !== null) {
		const block = m[1];
		const title = (block.match(/<title>(?:<!\[CDATA\[)?([\s\S]*?)(?:\]\]>)?<\/title>/)?.[1] ?? "").trim();
		const desc  = (block.match(/<description>(?:<!\[CDATA\[)?([\s\S]*?)(?:\]\]>)?<\/description>/)?.[1] ?? "").trim();
		const link  = (block.match(/<link>([\s\S]*?)<\/link>/)?.[1] ?? "").trim();
		const date  = (block.match(/<pubDate>([\s\S]*?)<\/pubDate>/)?.[1] ?? "").trim();
		if (title && link) items.push({ title, description: desc, link, pubDate: date });
	}
	return items;
}

let blogPosts: BlogPost[] = [];
try {
	const rssRes = await fetch("https://blog.02labs.me/rss.xml", {
		signal: AbortSignal.timeout(3000),
		headers: { Accept: "application/rss+xml, application/xml, text/xml" },
	});
	if (rssRes.ok) {
		const xml = await rssRes.text();
		blogPosts = parseRssItems(xml).slice(0, 4);
	}
} catch {
	// fallback — static CTA shown when RSS is unreachable
}
---

<BaseLayout
	title="02Labs"
	description="02Labs portfolio: featured projects, deep dives, and a writing archive."
	ogType="website"
	canonical="https://02labs.me/"
	jsonLd={jsonLd}
>
	<Navbar />
	<main id="main" class="home-main">
		<div class="card-stack">

		<Hero />

		<section class="snap-section" id="intro" data-snap-section>
			<div class="panel intro">
				<div class="intro-grid">
					<div>
						<h2>Introduction</h2>
						<p>
							Hi, I'm 02loveslollipop. I love technology, engineering, and building things in general. Even tough I'm a Computer and systems engineer &amp; Data science engineer, I have a wide range of interests and like to explore different areas. This is a personal portfolio site where I share projects, writeups, and other content related to my interests and work.
						</p>
					</div>
					<div class="intro-divider" aria-hidden="true"></div>
					<div>
						<h2>Focus (Or lack thereof)</h2>
						<p>
							I love lot's of things as you will see in my projects and blog. I think the best way to understand the world is by building, but something shouldn't be built just for the sake of building. I like to build things that are interesting, that solve problems, or that are just fun to me. But also I don't like to be superficial in what I learn whatever the topic is, for me that's a way to show respect to that thing and to myself.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="snap-section" id="ch0wn3rs" data-snap-section>
			<div class="panel">
				<div class="ch0wn3rs-header">
					<img
						class="ch0wn3rs-logo"
						src="/ch0wn3rs-logo.jpeg"
						alt="Ch0wn3rs team logo"
						width="80"
						height="80"
						loading="lazy"
					/>
					<div class="ch0wn3rs-meta">
						<h2>Ch0wn3rs</h2>
						<p class="ch0wn3rs-role">
							Co-founder &amp; CTO &mdash;
							<a href="https://ch0wn3rs.ninja" target="_blank" rel="noopener noreferrer">ch0wn3rs.ninja</a>
						</p>
						<p class="ch0wn3rs-desc">
							Elite cybersecurity CTF team. I manage the core infrastructure: web apps, CTF platforms, workshops, and instances.
						</p>
						<div class="ch0wn3rs-badges">
							<span class="badge" id="ctf-badge-country">Colombia #{team.country_place ?? 1}</span>
							<span class="badge" id="ctf-badge-world">World #{team.rating_place ?? "—"}</span>
							<span class="badge" id="ctf-badge-pts">{team.rating_points != null ? `${team.rating_points.toFixed(3)} pts` : "— pts"}</span>
						</div>
					</div>
				</div>

				<div class="ch0wn3rs-events">
					<div class="section-head ch0wn3rs-events-head">
						<div>
							<h3 id="ctf-year-heading">{ctfYear} CTF Participations</h3>
							<p id="ctf-rating-summary">
								Overall rating place: {team.rating_place ?? "—"} &mdash; {team.rating_points != null ? team.rating_points.toFixed(3) : "—"} pts
							</p>
						</div>
						<a class="btn" href="https://ctftime.org/team/408704" target="_blank" rel="noopener noreferrer">CTFtime profile</a>
					</div>
					<div class="ch0wn3rs-table-wrap">
						<table class="ch0wn3rs-table">
							<thead>
								<tr>
									<th>Place</th>
									<th>Event</th>
									<th>CTF pts</th>
								</tr>
							</thead>
							<tbody id="ctf-events-tbody">
								{events.map((ev) => (
									<tr>
										<td>{ev.place}</td>
										<td>{ev.title}</td>
										<td>{ev.ctf_points}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</section>

		<section class="snap-section" id="featured" data-snap-section>
			<div class="panel">
				<div class="section-head">
					<div>
						<h2>Featured projects</h2>
						<p>Five highlights. Static pages, crawlable links, and details below.</p>
					</div>
					<p>
						<a class="btn" href="/projects/">All projects</a>
					</p>
				</div>

				<div class="featured-row" aria-label="Featured projects">
					{featured.map((project) => (
						<ProjectCard project={project} detailsHref={`/projects/${project.slug}`} />
					))}
				</div>
			</div>
		</section>

		{featured.map((project) => (
			<section
				class="snap-section"
				id={`project-${project.slug}`}
				data-snap-section
			>
				<div class="panel">
					<ProjectDetail project={project} />
				</div>
			</section>
		))}

		<section class="snap-section" id="blog" data-snap-section>
			<div class="panel">
				<div class="section-head">
					<div>
						<h2>Blog</h2>
						<p>Writeups, notes, and long-form breakdowns.</p>
					</div>
					<a class="btn" href="https://blog.02labs.me/" target="_blank" rel="noopener noreferrer">All posts</a>
				</div>
				{blogPosts.length > 0 ? (
					<ul class="blog-posts">
						{blogPosts.map((post) => (
							<li class="blog-post-item">
								<a class="blog-post-link" href={post.link} target="_blank" rel="noopener noreferrer">
									<span class="blog-post-title">{post.title}</span>
									{post.pubDate ? (
										<time class="blog-post-date" datetime={new Date(post.pubDate).toISOString()}>
											{new Date(post.pubDate).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
										</time>
									) : null}
									{post.description ? (
										<p class="blog-post-desc">{post.description}</p>
									) : null}
								</a>
							</li>
						))}
					</ul>
				) : (
					<div class="cta">
						<p>The blog is deployed separately at <strong>blog.02labs.me</strong>.</p>
						<p><a class="btn" href="https://blog.02labs.me/" target="_blank" rel="noopener noreferrer">Open the blog</a></p>
					</div>
				)}
			</div>
		</section>

		</div><!-- .card-stack -->
	</main>

	<footer class="site-footer" aria-label="Footer">
		<div class="site-footer__inner">
			<p class="site-footer__copy">
				© {new Date().getFullYear()} 02Labs. Built with Astro.
			</p>
			<p class="site-footer__meta">
				<a href="/#top">Back to top</a>
			</p>
		</div>
	</footer>

	<script>
		import "../scripts/home";
	</script>

	<script>
		// Refresh Ch0wn3rs CTFtime data every 10 minutes without a full page reload.
		const POLL_MS = 10 * 60 * 1000;

		interface CTFEvent {
			event_id: string;
			title: string;
			place: number;
			ctf_points: string;
			time: number;
		}

		interface CTFTimeData {
			team: {
				rating_place: number | null;
				rating_points: number | null;
				country_place: number | null;
			};
			events: CTFEvent[];
			year: number;
		}

		function applyData(data: CTFTimeData) {
			const { team, events, year } = data;

			const countryBadge = document.getElementById("ctf-badge-country");
			const worldBadge   = document.getElementById("ctf-badge-world");
			const ptsBadge     = document.getElementById("ctf-badge-pts");
			const yearHeading  = document.getElementById("ctf-year-heading");
			const ratingSummary = document.getElementById("ctf-rating-summary");
			const tbody        = document.getElementById("ctf-events-tbody");

			if (countryBadge) countryBadge.textContent = `Colombia #${team.country_place ?? "—"}`;
			if (worldBadge)   worldBadge.textContent   = `World #${team.rating_place ?? "—"}`;
			if (ptsBadge)     ptsBadge.textContent     = team.rating_points != null
				? `${team.rating_points.toFixed(3)} pts`
				: "— pts";
			if (yearHeading)  yearHeading.textContent  = `${year} CTF Participations`;
			if (ratingSummary) ratingSummary.textContent =
				`Overall rating place: ${team.rating_place ?? "—"} — ${
					team.rating_points != null ? team.rating_points.toFixed(3) : "—"
				} pts`;

			if (tbody && events.length > 0) {
				tbody.innerHTML = events
					.map(
						(ev) =>
							`<tr><td>${ev.place}</td><td>${ev.title}</td><td>${ev.ctf_points}</td></tr>`
					)
					.join("");
			}
		}

		async function poll() {
			try {
				const res = await fetch("/api/ctftime.json");
				if (!res.ok) return;
				const data: CTFTimeData = await res.json();
				applyData(data);
			} catch {
				// silently ignore — stale server-rendered content stays visible
			}
		}

		// Kick off the first client refresh after 10 minutes, then repeat.
		const id = setInterval(poll, POLL_MS);
		// Clean up if the page is torn down (e.g. SPA navigation).
		document.addEventListener("astro:before-swap", () => clearInterval(id), { once: true });
	</script>
</BaseLayout>
