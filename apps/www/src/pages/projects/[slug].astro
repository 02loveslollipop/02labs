---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import ProjectDetail from "../../components/ProjectDetail.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
	const entries = await getCollection("projects");
	return entries.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { project: entry.data },
	}));
}

const { project } = Astro.props;
const projectUrl = Astro.site
	? new URL(`/projects/${project.slug}/`, Astro.site).toString()
	: `/projects/${project.slug}/`;
const jsonLd = JSON.stringify(
	[
		{
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			itemListElement: [
				{
					"@type": "ListItem",
					position: 1,
					name: "02Labs",
					item: Astro.site ? new URL("/", Astro.site).toString() : "/",
				},
				{
					"@type": "ListItem",
					position: 2,
					name: "Projects",
					item: Astro.site ? new URL("/projects/", Astro.site).toString() : "/projects/",
				},
				{
					"@type": "ListItem",
					position: 3,
					name: project.title,
					item: projectUrl,
				},
			],
		},
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			name: project.title,
			description: project.summary,
			url: projectUrl,
			breadcrumb: {
				"@type": "BreadcrumbList",
				itemListElement: [
					{
						"@type": "ListItem",
						position: 1,
						name: "02Labs",
						item: Astro.site ? new URL("/", Astro.site).toString() : "/",
					},
					{
						"@type": "ListItem",
						position: 2,
						name: "Projects",
						item: Astro.site ? new URL("/projects/", Astro.site).toString() : "/projects/",
					},
					{
						"@type": "ListItem",
						position: 3,
						name: project.title,
						item: projectUrl,
					},
				],
			},
			isPartOf: {
				"@type": "WebSite",
				name: "02Labs",
				url: Astro.site ? new URL("/", Astro.site).toString() : "/",
			},
		},
	],
	null,
	0
);
---

<BaseLayout
        title={project.title}
        description={project.summary}
        ogType="website"
        jsonLd={jsonLd}
>
        <Navbar forceScrolled />

        <main id="main" class="project-page">
                <div class="project-page__shell panel">
                        <nav class="project-page__breadcrumb" aria-label="Breadcrumb">
                                <a href="/">Home</a>
                                <span aria-hidden="true"> / </span>
                                <a href="/projects/">Projects</a>
                                <span aria-hidden="true"> / </span>
                                <span>{project.title}</span>
                        </nav>

                        <ProjectDetail project={project} headingTag="h1" />
                </div>
        </main>

        <footer class="site-footer" aria-label="Footer">
                <div class="site-footer__inner">
                        <p class="site-footer__copy">
                                © {new Date().getFullYear()} 02Labs. Built with Astro.
                        </p>
                        <p class="site-footer__meta">
                                <a href="/projects/">Back to projects</a>
                        </p>
                </div>
        </footer>
</BaseLayout>

<style>
        .project-page {
                min-height: 100dvh;
                padding-block-start: var(--nav-h, 4rem);
                padding: calc(var(--nav-h, 4rem) + 2rem) var(--pad, 1.5rem) 4rem;
                display: grid;
                place-items: start center;
        }

        .project-page__shell {
                /* Override panel's fixed-height from the card-stack context */
                height: auto !important;
                width: min(900px, calc(100vw - (var(--pad, 1.5rem) * 2)));
                max-width: 900px;
        }

        .project-page__breadcrumb {
                font-size: 0.875rem;
                color: var(--color-muted, #888);
                margin-block-end: 2rem;
        }

        .project-page__breadcrumb a {
                color: inherit;
                text-decoration: underline;
                text-underline-offset: 2px;
        }

        .project-page__breadcrumb a:hover {
                color: var(--color-fg, #fff);
        }
</style>
