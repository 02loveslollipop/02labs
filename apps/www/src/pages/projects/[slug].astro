---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import ProjectDetail from "../../components/ProjectDetail.astro";
import { getCollection } from "astro:content";

const { slug } = Astro.params;

const entries = await getCollection("projects");
const entry = entries.find((e) => e.data.slug === slug);

if (!entry) {
        return Astro.redirect("/projects/");
}

const project = entry.data;
---

<BaseLayout
        title={`${project.title} – 02Labs`}
        description={project.summary}
        ogType="website"
        canonical={`https://02labs.me/projects/${project.slug}`}
>
        <Navbar forceScrolled />

        <main id="main" class="project-page">
                <div class="project-page__shell panel">
                        <nav class="project-page__breadcrumb" aria-label="Breadcrumb">
                                <a href="/">Home</a>
                                <span aria-hidden="true"> / </span>
                                <a href="/projects/">Projects</a>
                                <span aria-hidden="true"> / </span>
                                <span>{project.title}</span>
                        </nav>

                        <ProjectDetail project={project} />
                </div>
        </main>

        <footer class="site-footer" aria-label="Footer">
                <div class="site-footer__inner">
                        <p class="site-footer__copy">
                                © {new Date().getFullYear()} 02Labs. Built with Astro.
                        </p>
                        <p class="site-footer__meta">
                                <a href="/projects/">Back to projects</a>
                        </p>
                </div>
        </footer>
</BaseLayout>

<style>
        .project-page {
                min-height: 100dvh;
                padding-block-start: var(--nav-h, 4rem);
                padding: calc(var(--nav-h, 4rem) + 2rem) var(--pad, 1.5rem) 4rem;
                display: grid;
                place-items: start center;
        }

        .project-page__shell {
                /* Override panel's fixed-height from the card-stack context */
                height: auto !important;
                width: min(900px, calc(100vw - (var(--pad, 1.5rem) * 2)));
                max-width: 900px;
        }

        .project-page__breadcrumb {
                font-size: 0.875rem;
                color: var(--color-muted, #888);
                margin-block-end: 2rem;
        }

        .project-page__breadcrumb a {
                color: inherit;
                text-decoration: underline;
                text-underline-offset: 2px;
        }

        .project-page__breadcrumb a:hover {
                color: var(--color-fg, #fff);
        }
</style>
