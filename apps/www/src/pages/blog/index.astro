---
export const prerender = false;

import blogArchiveSettings from "../../data/blog-archive-settings.json";
import ArchiveTagBar from "../../components/blog/ArchiveTagBar.astro";
import EmptyFeaturedMedia from "../../components/blog/EmptyFeaturedMedia.astro";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { fetchBlogMirrorPosts } from "../../lib/blog";
import type { BlogArchivePost } from "../../lib/blog";
import {
	BLOG_AUTHOR,
	BLOG_DESCRIPTION,
	BLOG_LOCALE,
	BLOG_NAME,
	BLOG_PUBLISHER,
	type BlogTagSummary,
	resolveSiteUrl,
	slugifyTag,
} from "../../lib/blog-posts";

function getTagSummaries(posts: BlogArchivePost[]): BlogTagSummary[] {
	const tagMap = new Map<string, BlogTagSummary>();

	for (const post of posts) {
		for (const tag of post.tags) {
			const slug = slugifyTag(tag);
			if (!slug) continue;
			const existing = tagMap.get(slug);
			if (existing) {
				existing.count += 1;
				continue;
			}
			tagMap.set(slug, {
				slug,
				label: tag,
				count: 1,
			});
		}
	}

	return Array.from(tagMap.values()).sort((a, b) => {
		if (b.count !== a.count) return b.count - a.count;
		return a.label.localeCompare(b.label);
	});
}

Astro.response.headers.set("Cache-Control", "public, s-maxage=900, stale-while-revalidate=86400");

const posts = await fetchBlogMirrorPosts();
const configuredFeaturedSlug = String(blogArchiveSettings.featuredSlug || "").trim();
const featured =
	posts.find((post) => post.slug === configuredFeaturedSlug) ??
	posts[0] ??
	null;
const archivePosts = featured
	? posts.filter((post) => post.slug !== featured.slug)
	: posts;
const tagSummaries = getTagSummaries(posts);
const blogUrl = Astro.site ? new URL("/blog/", Astro.site).toString() : "/blog/";
const jsonLd = JSON.stringify(
	[
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			name: BLOG_NAME,
			description: BLOG_DESCRIPTION,
			url: blogUrl,
			inLanguage: BLOG_LOCALE,
		},
		{
			"@context": "https://schema.org",
			"@type": "Blog",
			name: BLOG_NAME,
			description: BLOG_DESCRIPTION,
			url: blogUrl,
			inLanguage: BLOG_LOCALE,
			author: {
				"@type": "Person",
				name: BLOG_AUTHOR.name,
				url: BLOG_AUTHOR.url,
				sameAs: [...BLOG_AUTHOR.sameAs],
			},
			publisher: {
				"@type": "Organization",
				name: BLOG_PUBLISHER.name,
				url: BLOG_PUBLISHER.url,
				logo: {
					"@type": "ImageObject",
					url: resolveSiteUrl(BLOG_PUBLISHER.logoPath, Astro.site),
				},
			},
		},
		{
			"@context": "https://schema.org",
			"@type": "ItemList",
			name: `${BLOG_NAME} Posts`,
			itemListElement: posts.map((post, index) => ({
				"@type": "ListItem",
				position: index + 1,
				name: post.title,
				url: post.url,
			})),
		},
	],
	null,
	0
);
---

<BlogLayout title="Blog" description={BLOG_DESCRIPTION} ogType="website" jsonLd={jsonLd} canonical={blogUrl}>
	<main class="wrap" id="main">
		<section class="arc-hero">
			<div class="eyebrow">
				<span>02Labs</span>
				<span class="dot"></span>
				<span>THE BLOG</span>
			</div>
			<h1>02loveslollipop's Blog</h1>
			<p>
				Mostly Crypto CTF writeups/deep dives and whatever I feel like writing about
			</p>
		</section>

		<ArchiveTagBar allCount={posts.length} tagSummaries={tagSummaries} />

		{featured ? (
			<a class="featured" href={featured.url}>
				<div class="featured__img">
					{featured.imageSrc ? (
						<img
							src={featured.imageSrc}
							alt={`${featured.title} preview`}
							loading="eager"
							decoding="async"
						/>
					) : (
						<EmptyFeaturedMedia />
					)}
				</div>
				<div class="featured__body">
					<div>
						<div class="featured__tags">
							{featured.tags.slice(0, 3).map((tag, index) => (
								<span class={index === 0 ? "tag-a" : "tag-g"}>{tag}</span>
							))}
						</div>
						<div style="height: 18px" aria-hidden="true"></div>
						<h2>{featured.title}</h2>
						<div style="height: 14px" aria-hidden="true"></div>
						<p>{featured.excerpt}</p>
					</div>
					<div class="featured__foot">
						<span>{featured.pubDateDisplay} · {featured.readTimeLabel}</span>
						<span class="cta">READ POST →</span>
					</div>
				</div>
			</a>
		) : null}

		<div class="list" role="list">
			{archivePosts.map((post, index) => (
				<a class="post-row" href={post.url} role="listitem">
					<span class="pr-num">
						{String(index + 1).padStart(2, "0")} · {post.pubDateCode}
					</span>
					<span class="pr-cat">
						{post.tags.slice(0, 2).map((tag) => tag.toUpperCase()).join(" · ")}
					</span>
					<span class="pr-title">{post.title}</span>
					<span class="pr-meta">
						<span>{post.readTimeLabel}</span>
						<span>{post.pubDateDisplay.replace(",", "")}</span>
					</span>
					<span class="pr-arrow">→</span>
				</a>
			))}
		</div>

		<footer class="arc-foot">
			<span>END OF ARCHIVE · {String(posts.length).padStart(2, "0")} POSTS</span>
			<a href="https://blog.02labs.me/rss.xml">RSS FEED →</a>
		</footer>
	</main>
</BlogLayout>
